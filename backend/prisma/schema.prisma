// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("JILA_BACKEND_PRISMA_DATABASE_URL") // uses connection pooling
  directUrl = env("JILA_BACKEND_POSTGRES_URL") // uses a direct connection
}

model AdminUser {
  id           String   @id @default(cuid())
  clerkId      String   @unique
  email        String   @unique
  communityOrg String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AppUser {
  id           String   @id @default(cuid())
  clerkId      String   @unique
  username     String   @unique
  communityOrg String
  language     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model videos {
  id          Int           @id @default(autoincrement())
  title       String
  category    VideoCategory
  source      VideoSource
  length      Int // Seconds
  url         String        @unique
  uploadDate  DateTime
  description String
  likes       Int
  dislikes    Int
  language    String
}

enum VideoSource {
  YOUTUBE
  GOOGLE_DRIVE
  INSTAGRAM
  TIK_TOK
}

enum VideoCategory {
  PROFESSIONAL_DEVELOPMENT
  MEDICAL
  TRANSPORTATION
  LEGAL
  OTHER
}
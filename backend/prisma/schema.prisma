// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("JILA_BACKEND_PRISMA_DATABASE_URL") // uses connection pooling
  directUrl = env("JILA_BACKEND_POSTGRES_URL") // uses a direct connection
}

model AdminUser {
  id           String   @id @default(cuid())
  clerkId      String   @unique
  email        String   @unique
  communityOrg String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AppUser {
  id           String   @id @default(cuid())
  clerkId      String   @unique
  username     String   @unique
  communityOrg String
  language     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Videos {
  id                  Int        @id @default(autoincrement())
  titleEnglish        String
  titleQanjobal       String
  audioFile           Bytes
  topic               VideoTopic
  url                 String     @unique
  uploadDate          DateTime
  descriptionEnglish  String
  descriptionQanjobal String
}

model SocialServices {
  id           Int                   @id @default(autoincrement())
  title        String
  category     SocialServiceCategory
  phone_number String                @unique @db.VarChar(20)
  address      String?
  description  String?
  url          String?               @unique
}

enum VideoTopic {
  TRANSPORT
  LEGAL
  MEDICAL
  CAREER
  EDUCATION
  OTHER
}

enum SocialServiceCategory {
  EMERGENCIA
  SHELTERS
  FOOD
  TRANSPORTATION
  OTHER
}

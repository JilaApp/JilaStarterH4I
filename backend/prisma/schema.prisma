// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("JILA_BACKEND_PRISMA_DATABASE_URL") // uses connection pooling
  directUrl = env("JILA_BACKEND_POSTGRES_URL") // uses a direct connection
}

model users {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  image     String
  createdAt DateTime @default(now())
}

model videos {
  id          Int           @id @default(autoincrement())
  title       String
  category    VideoCategory
  source      VideoSource
  length      Int // Seconds
  url         String        @unique
  uploadDate  DateTime
  description String
  likes       Int
  dislikes    Int
  language    String
}

model social_services {
  id            Int            @id @default(autoincrement())
  title         String
  category      SocialServiceCategory
  phone_number  Int?           @unique
  address       String?
  description   String?
  url           String?        @unique
}


enum VideoSource {
  YOUTUBE
  GOOGLE_DRIVE
  INSTAGRAM
  TIK_TOK
}

enum VideoCategory {
  PROFESSIONAL_DEVELOPMENT
  MEDICAL
  TRANSPORTATION
  LEGAL
  OTHER
}

enum SocialServiceCategory {
  EMERGENCIA
  SHELTERS
  FOOD
  TRANSPORTATION
  OTHER
}

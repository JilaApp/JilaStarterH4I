// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("JILA_BACKEND_PRISMA_DATABASE_URL") // uses connection pooling
  directUrl = env("JILA_BACKEND_POSTGRES_URL") // uses a direct connection
}

model AdminUser {
  id           String   @id @default(cuid())
  clerkId      String   @unique
  email        String   @unique
  communityOrg String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AppUser {
  id           String   @id @default(cuid())
  clerkId      String   @unique
  username     String   @unique
  communityOrg String
  language     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Videos {
  id                  Int      @id @default(autoincrement())
  titleEnglish        String
  titleQanjobal       String
  audioFile           Bytes?
  audioFilename       String?
  audioFileSize       Int?
  topic               VideoTopic
  url                 String   @unique
  uploadDate          DateTime
  descriptionEnglish  String?
  descriptionQanjobal String?
}

model SocialServices {
  id           Int                   @id @default(autoincrement())
  title        String
  category     SocialServiceCategory
  phone_number String                @unique @db.VarChar(20)
  address      String?
  description  String?
  url          String?               @unique
  titleAudioFilename String?
  titleAudioFileSize Int?
  titleAudioFile String? // base64 encoded
  descriptionAudioFilename String?
  descriptionAudioFileSize Int?
  descriptionAudioFile String?
}

model Jobs {
  id                  Int      @id @default(autoincrement())
  titleEnglish        String
  titleQanjobal       String
  companyName         String
  jobType             JobType
  locationType        LocationType
  city                String
  state               String
  url                 String   @unique
  salary              Int
  expirationDate      DateTime
  descriptionEnglish  String
  descriptionQanjobal String
}

enum VideoTopic {
  TRANSPORT
  LEGAL
  MEDICAL
  CAREER
  EDUCATION
  OTHER
}

enum SocialServiceCategory {
  EMERGENCIA
  SHELTERS
  FOOD
  TRANSPORTATION
  OTHER
}

enum JobType {
  INTERNSHIP
  FULLTIME
  QANJOBAL
  PARTTIME
  TEMPORARY
  FREELANCE
  SEASONAL
}

enum LocationType {
  REMOTE
  HYBRID
  INPERSON
}
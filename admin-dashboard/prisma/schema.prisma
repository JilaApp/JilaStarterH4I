// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("JILA_BACKEND_PRISMA_DATABASE_URL") // uses connection pooling
  directUrl = env("JILA_BACKEND_POSTGRES_URL") // uses a direct connection
}

model AdminUser {
  id           String   @id @default(cuid())
  clerkId      String   @unique
  email        String   @unique
  communityOrg String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AppUser {
  id           String   @id @default(cuid())
  clerkId      String   @unique
  username     String   @unique
  communityOrg String
  language     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Videos {
  id                  Int      @id @default(autoincrement())
  titleEnglish        String
  titleQanjobal       String
  audioFileS3Key      String?
  audioFilename       String?
  audioFileSize       Int?
  topic               VideoTopic
  urls                String[]
  uploadDate          DateTime
  descriptionEnglish  String?
  descriptionQanjobal String?
}

model SocialServices {
  id           Int                   @id @default(autoincrement())
  title        String
  category     SocialServiceCategory
  phone_number String                @unique @db.VarChar(20)
  address      String?
  description  String?
  url          String?               @unique
  titleAudioFilename String?
  titleAudioFileSize Int?
  titleAudioFileS3Key String?
  descriptionAudioFilename String?
  descriptionAudioFileSize Int?
  descriptionAudioFileS3Key String?
}

model Jobs {
  id                   Int              @id @default(autoincrement())
  titleEnglish         String
  titleQanjobal        String
  companyName          String
  businessContactEmail String
  jobType              JobType
  acceptedLanguages    String[]         @default([])
  locationType         LocationType
  city                 String
  state                String
  url                  String           @unique
  salary               Int
  expirationDate       DateTime
  descriptionEnglish   String
  descriptionQanjobal  String
  status               JobStatus        @default(ACTIVE)
  unread               Boolean          @default(true)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
}

enum VideoTopic {
  TRANSPORT
  LEGAL
  MEDICAL
  CAREER
  EDUCATION
  OTHER
}

enum SocialServiceCategory {
  EMERGENCIA
  SHELTERS
  FOOD
  TRANSPORTATION
  OTHER
}

enum JobType {
  INTERNSHIP
  FULLTIME
  QANJOBAL
  PARTTIME
  TEMPORARY
  FREELANCE
  SEASONAL
}

enum LocationType {
  REMOTE
  HYBRID
  INPERSON
}

enum JobStatus {
  PENDING
  ACTIVE
  ARCHIVED
}
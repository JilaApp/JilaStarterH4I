// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("JILA_BACKEND_PRISMA_DATABASE_URL") // uses connection pooling
  directUrl = env("JILA_BACKEND_POSTGRES_URL") // uses a direct connection
}

model CommunityOrg {
  id            String          @id @default(cuid())
  name          String          @unique
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  adminUsers    AdminUser[]
  videos        Videos[]
  socialServices SocialServices[]
  jobs          Jobs[]
}

model AdminUser {
  id             String        @id @default(cuid())
  clerkId        String        @unique
  email          String        @unique
  role           AdminRole     @default(COMMUNITY_ORG_ADMIN)
  communityOrgId String?
  communityOrg   CommunityOrg? @relation(fields: [communityOrgId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

enum AdminRole {
  JILA_ADMIN
  COMMUNITY_ORG_ADMIN
}

model AppUser {
  id           String   @id @default(cuid())
  clerkId      String   @unique
  username     String   @unique
  communityOrg String
  language     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Videos {
  id                  Int           @id @default(autoincrement())
  titleEnglish        String
  titleQanjobal       String
  audioFile           Bytes?
  audioFilename       String?
  audioFileSize       Int?
  topic               VideoTopic
  urls                String[]
  uploadDate          DateTime
  descriptionEnglish  String?
  descriptionQanjobal String?
  communityOrgId      String?
  communityOrg        CommunityOrg? @relation(fields: [communityOrgId], references: [id])
}

model SocialServices {
  id                       Int                   @id @default(autoincrement())
  title                    String
  category                 SocialServiceCategory
  phone_number             String                @unique @db.VarChar(20)
  address                  String?
  description              String?
  url                      String?               @unique
  titleAudioFilename       String?
  titleAudioFileSize       Int?
  titleAudioFile           String? // base64 encoded
  descriptionAudioFilename String?
  descriptionAudioFileSize Int?
  descriptionAudioFile     String?
  communityOrgId           String?
  communityOrg             CommunityOrg?         @relation(fields: [communityOrgId], references: [id])
}

model Jobs {
  id                   Int              @id @default(autoincrement())
  titleEnglish         String
  titleQanjobal        String
  companyName          String
  businessContactEmail String
  jobType              JobType
  acceptedLanguages    String[]         @default([])
  locationType         LocationType
  city                 String
  state                String
  url                  String           @unique
  salary               Int
  expirationDate       DateTime
  descriptionEnglish   String
  descriptionQanjobal  String
  status               JobStatus        @default(ACTIVE)
  unread               Boolean          @default(true)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  communityOrgId       String?
  communityOrg         CommunityOrg?    @relation(fields: [communityOrgId], references: [id])
}

enum VideoTopic {
  TRANSPORT
  LEGAL
  MEDICAL
  CAREER
  EDUCATION
  OTHER
}

enum SocialServiceCategory {
  EMERGENCIA
  SHELTERS
  FOOD
  TRANSPORTATION
  OTHER
}

enum JobType {
  INTERNSHIP
  FULLTIME
  QANJOBAL
  PARTTIME
  TEMPORARY
  FREELANCE
  SEASONAL
}

enum LocationType {
  REMOTE
  HYBRID
  INPERSON
}

enum JobStatus {
  PENDING
  ACTIVE
  ARCHIVED
}